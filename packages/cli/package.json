{
  "name": "latticeui-cli",
  "version": "1.0.0",
  "description": "LatticeUI CLI: add/eject component source into your repo with a lockfile, and pull upstream updates via 3-way merge.",
  "license": "MIT",
  "author": "Amit Chowdhary (https://github.com/amit641)",
  "homepage": "https://amit641.github.io/latticeui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amit641/latticeui.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/amit641/latticeui/issues",
  "keywords": ["cli", "design-system", "scaffolding", "codegen", "latticeui"],
  "type": "module",
  "bin": {
    "latticeui": "./dist/index.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "node-diff3": "^3.1.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
