{
  "name": "@tessera/tokens",
  "version": "1.0.0",
  "description": "Tessera design tokens: W3C token JSON compiled to layered CSS variables and typed TS maps",
  "license": "MIT",
  "author": "Amit Chowdhary (https://github.com/amit641)",
  "homepage": "https://amit641.github.io/tessera",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amit641/tessera.git",
    "directory": "packages/tokens"
  },
  "bugs": "https://github.com/amit641/tessera/issues",
  "keywords": ["design-tokens", "design-system", "css-variables", "theming", "tessera"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": ["dist"],
  "sideEffects": ["*.css"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build-tokens.mjs"
  }
}
