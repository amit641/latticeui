{
  "name": "latticeui-react",
  "version": "1.0.0",
  "description": "LatticeUI React adapter: composable part components and hooks over the framework-agnostic core.",
  "license": "MIT",
  "author": "Amit Chowdhary (https://github.com/amit641)",
  "homepage": "https://amit641.github.io/latticeui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amit641/latticeui.git",
    "directory": "packages/react"
  },
  "bugs": "https://github.com/amit641/latticeui/issues",
  "keywords": ["react", "design-system", "components", "ui", "accessibility", "headless", "latticeui"],
