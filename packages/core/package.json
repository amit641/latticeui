{
  "name": "latticeui-core",
  "version": "1.0.1",
  "description": "LatticeUI framework-agnostic core: state machines, anatomy contracts, and DOM utilities. Zero dependencies.",
  "license": "MIT",
  "author": "Amit Chowdhary (https://github.com/amit641)",
  "homepage": "https://amit641.github.io/latticeui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amit641/latticeui.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/amit641/latticeui/issues",
  "keywords": ["design-system", "state-machine", "headless-ui", "accessibility", "latticeui"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
